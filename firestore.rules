rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.get("role", null) == "admin";
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Audit AR module roles ──
    function auditRole() {
      let tokenRole = isAuthenticated()
        ? request.auth.token.get("auditRole", null)
        : null;
      let data = isAuthenticated()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
      let modules = data.get("modules", {});
      let auditAr = modules.get("auditAr", {});
      let docRole = auditAr.get("enabled", false) == true
        ? auditAr.get("role", null)
        : null;
      return docRole != null ? docRole : tokenRole;
    }
    function isSupervisor() {
      return auditRole() == "supervisor";
    }
    function isFieldAudit() {
      return auditRole() == "fieldAudit";
    }
    // A supervisor can also do field-audit work; a field auditor cannot supervise.
    function canFieldAudit() {
      return isSupervisor() || isFieldAudit();
    }
    function hasAuditAccess() {
      return isSupervisor() || isFieldAudit();
    }
    function isDefaultSupervisorModule() {
      return request.resource.data.modules.keys().hasOnly(['auditAr'])
        && request.resource.data.modules.auditAr.keys().hasOnly([
          'enabled', 'role', 'grantedAt', 'grantedBy'
        ])
        && request.resource.data.modules.auditAr.enabled == true
        && request.resource.data.modules.auditAr.role == "supervisor"
        && request.resource.data.modules.auditAr.grantedBy == "default-signup";
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'role', 'createdAt', 'lastLoginAt',
          'isDisabled', 'modules'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.role == "user"
        && request.resource.data.isDisabled == false
        && isDefaultSupervisorModule();
      allow update: if isAdmin()
        || (isOwner(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['displayName', 'lastLoginAt']));
      allow delete: if isAdmin();
    }

    // ── Audit AR module ──

    match /auditUnits/{unitId} {
      allow read: if hasAuditAccess();
      allow create, delete: if isSupervisor();
      // Supervisor may update anything; Field Audit may only touch the draft/lock
      // lifecycle fields of a unit it owns, and may never set status to approved.
      allow update: if isSupervisor()
        || (isFieldAudit()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'lock', 'currentSubmissionId',
                           'submissionCount', 'lastSubmittedAt', 'updatedAt',
                           'draft'])
            && request.resource.data.status in
                 ['not_started', 'draft', 'pending', 'rejected']
            && (request.resource.data.lock == null
                || request.resource.data.lock.lockedBy == request.auth.uid));

      match /submissions/{submissionId} {
        allow read: if hasAuditAccess();
        // Field Audit (or a Supervisor acting as one) creates its own submission;
        // cannot pre-set review fields.
        allow create: if canFieldAudit()
          && request.resource.data.submittedBy == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.reviewedBy == null;
        // Only Supervisor sets the review outcome; everything else is immutable.
        allow update: if isSupervisor()
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'reviewedBy', 'reviewedByName',
                         'reviewedAt', 'rejectionNote']);
        allow delete: if false; // history preserved forever
      }
    }

    match /auditCategories/{categoryId} {
      allow read: if hasAuditAccess();
      allow create, update, delete: if isSupervisor();
    }

    match /auditImports/{importId} {
      allow read: if hasAuditAccess();
      allow create: if isSupervisor();
      allow update, delete: if false;
    }

    // Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
